# YooKassa API Credentials
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY=your_secret_key_here

# Email настройки (SMTP)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@domain.ru
SMTP_PASS=your_password
EMAIL_FROM=SAASPRENER <noreply@saasprener.online>

# Admin email для уведомлений
ADMIN_EMAIL=admin@saasprener.online

# Сайт
SITE_URL=https://saasprener.online

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_chat_id

# База данных
DATABASE_PATH=./data/analytics.db

# Сервер
PORT=3001
NODE_ENV=production
TZ=Europe/Moscow
